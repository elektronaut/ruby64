#!/usr/bin/env ruby
# frozen_string_literal: true

lib = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift(lib) unless $LOAD_PATH.include?(lib)

require "optparse"

BATCHES = 10

options = { jit: true, cycles: 10_000_000 }

parser = OptionParser.new do |opts|
  opts.banner = <<~BANNER
    Usage: bin/benchmark [options] [media]

    Media can be a .prg/.p00 program, a .d64/.d71/.d81 disk image,
    a .crt cartridge, or a directory to mount as device 8.

    Boots the machine (and autostarts the media, if given), fast-forwards
    past startup, then measures a fixed number of emulated cycles.

    Options:
  BANNER

  opts.on("--cycles N", Integer, "Cycles to measure (default: 10000000)") do |n|
    options[:cycles] = n
  end

  opts.on("--fast-forward N", Integer,
          "Cycles to skip before measuring " \
          "(default: 3000000, or 5000000 with media)") do |n|
    options[:fast_forward] = n
  end

  opts.on("--disable-jit", "Run without enabling YJIT") do
    options[:jit] = false
  end

  opts.on("-h", "--help", "Show this help") do
    puts opts
    exit
  end
end

begin
  parser.parse!
rescue OptionParser::ParseError => e
  warn "benchmark: #{e.message}"
  warn "Try 'bin/benchmark --help' for more information."
  exit 1
end

media_path = ARGV[0]
if media_path && !File.exist?(media_path)
  warn "benchmark: no such file or directory: #{media_path}"
  exit 1
end

jit_available = defined?(RubyVM::YJIT) && !RubyVM::YJIT.enabled?
RubyVM::YJIT.enable if options[:jit] && jit_available

require "badline"

def monotonic_time
  Process.clock_gettime(Process::CLOCK_MONOTONIC)
end

def format_rate(cycles, elapsed)
  rate = cycles / elapsed
  speed = rate / Badline::TimeOfDay::CLOCK_HZ
  format("%<rate>9d cycles/s (%<speed>.2fx real time)", rate:, speed:)
end

computer = Badline::Computer.new
puts Badline::Media.attach(computer, media_path) if media_path

fast_forward = options[:fast_forward] || (media_path ? 5_000_000 : 3_000_000)
print "Booting (#{fast_forward} cycles)... "
computer.cycle! while computer.cycles < fast_forward
puts "done."

batch_size = options[:cycles] / BATCHES
total_elapsed = 0.0

BATCHES.times do |i|
  started = monotonic_time
  batch_size.times { computer.cycle! }
  elapsed = monotonic_time - started
  total_elapsed += elapsed
  puts "Batch #{i + 1}/#{BATCHES}: #{format_rate(batch_size, elapsed)}"
end

puts
puts "Total: #{format_rate(batch_size * BATCHES, total_elapsed)}"
puts "Cycles: #{computer.cycles}, instructions: #{computer.cpu.instructions}"
